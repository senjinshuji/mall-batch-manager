rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sales_data/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /batch_logs/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /settings/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /registered_products/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /event_flags/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /product_sales/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /sync_logs/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /amazon_daily_sales/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /tiktok_accounts/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /tiktok_videos/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /tiktok_video_daily_snapshots/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /rakuten_daily_sales/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /client_accounts/{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
